# ───────────────────────────────────────────────────────────────────────────
# Optera environment template. Copy to `.env` (engine) and `.env.local` (web).
# NEVER commit real secrets. Web-exposed vars must be prefixed NEXT_PUBLIC_.
# ───────────────────────────────────────────────────────────────────────────

# ── Web (apps/web/.env.local) ────────────────────────────────────────────────
NEXT_PUBLIC_ENGINE_URL=http://localhost:8000
NEXT_PUBLIC_ENGINE_WS_URL=ws://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Engine (apps/engine/.env) ────────────────────────────────────────────────
ENVIRONMENT=development
ENGINE_HOST=0.0.0.0
ENGINE_PORT=8000
# Comma-separated list of allowed CORS origins for the web app
CORS_ORIGINS=http://localhost:3000

# Supabase (server-side; service role key NEVER goes to the client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Token encryption (32-byte urlsafe base64 Fernet key). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Redis (Upstash) — cache / pub-sub / rate limit
REDIS_URL=redis://localhost:6379

# ── Broker ───────────────────────────────────────────────────────────────────
# Active data broker for positions/holdings/market-data. Set BROKER=mock for a
# fully synthetic NIFTY/BANKNIFTY demo book that needs NO Upstox credentials
# (great for local dev / demos). Default `upstox` reads your real positions.
BROKER=upstox

# ── Broker: Upstox (free) ────────────────────────────────────────────────────
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=http://localhost:3000/auth/broker/callback
# One-time analytics token for market-data + websocket (no daily re-auth)
UPSTOX_ANALYTICS_TOKEN=

# ── Quant defaults ───────────────────────────────────────────────────────────
RISK_FREE_RATE=0.065

# ── AI (route everything through the LLM gateway) ────────────────────────────
# Chat / tool-calling
AI_CHAT_PROVIDER=gemini
AI_CHAT_MODEL=gemini-3-flash
GEMINI_API_KEY=
# Alert phrasing (high-frequency, cheap/fast)
AI_ALERT_PROVIDER=groq
AI_ALERT_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=

# ── Notifications ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Billing (Razorpay) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
